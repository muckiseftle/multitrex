---
/**
 * AR-Himmelsscanner (Beta): öffnet die Rückkamera im Vollbild und blendet über
 * das Live-Bild die echten Positionen von Sonne, Mond und den hellen Planeten
 * ein — Handy an den Himmel halten. Rein clientseitig (Kamera/Sensoren/Standort
 * verlassen das Gerät nicht). Am besten mobil mit Bewegungssensoren.
 */
---

<button type="button" class="scanner-open" data-scanner-open>
  <span class="scanner-open__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M3 8V5a2 2 0 0 1 2-2h3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3" />
      <circle cx="12" cy="12" r="3.2" />
    </svg>
  </span>
  <span class="scanner-open__text">
    <span class="scanner-open__title">Himmels-Scanner öffnen</span>
    <span class="label scanner-open__sub">Handy an den Himmel halten · Beta</span>
  </span>
  <span class="label label--accent scanner-open__go" aria-hidden="true">AR</span>
</button>

<div class="scanner" id="sky-scanner" hidden>
  <video class="scanner__video" playsinline muted></video>
  <canvas class="scanner__canvas"></canvas>

  <!-- ========== Start-Screen ========== -->
  <div class="scanner__intro" data-intro>
    <button type="button" class="scanner__x" data-scanner-close aria-label="Schließen">✕</button>
    <div class="scanner__introcard">
      <span class="scanner__introicon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
          <path d="M3 8V5a2 2 0 0 1 2-2h3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3" />
          <circle cx="12" cy="12" r="3.2" />
        </svg>
      </span>
      <h2 class="scanner__introtitle">Himmels-Scanner</h2>
      <p class="scanner__introlead">
        Halte dein Handy an den Himmel — der Scanner zeigt dir live, wo Sonne,
        Mond und die Planeten gerade stehen.
      </p>
      <ol class="scanner__steps">
        <li><span class="scanner__num">1</span> Kamera &amp; Bewegung erlauben</li>
        <li><span class="scanner__num">2</span> Handy nach oben zum Himmel halten</li>
        <li><span class="scanner__num">3</span> Den beschrifteten Markern folgen</li>
      </ol>
      <button type="button" class="scanner__start" data-scanner-start>Scanner starten</button>
      <p class="scanner__fineprint label" data-intro-note>
        Am besten am Handy · nichts wird gespeichert oder gesendet
      </p>
    </div>
  </div>

  <!-- ========== Live-AR ========== -->
  <div class="scanner__ui" data-liveui hidden>
    <div class="scanner__top">
      <p class="label scanner__heading">
        <span class="scanner__compass" aria-hidden="true">🧭</span>
        <span data-scanner-heading>—</span>
      </p>
      <button type="button" class="scanner__close" data-scanner-close aria-label="Scanner schließen">✕</button>
    </div>

    <p class="scanner__status label" data-scanner-status></p>

    <div class="scanner__toast label" data-scanner-toast>
      Schwenke dein Handy langsam über den Himmel
    </div>

    <div class="scanner__bottom">
      <div class="scanner__legend">
        <span><i class="dot dot--planet"></i> Planet / Mond / Sonne</span>
        <span><i class="dot dot--arrow">➤</i> Pfeil = dorthin drehen</span>
        <span><i class="dot dot--num">20°</i> Höhe über dem Horizont</span>
      </div>
      <div class="scanner__calibrow">
        <span class="label scanner__calibhint">Marker leicht daneben? Nord justieren:</span>
        <div class="scanner__calib">
          <button type="button" class="scanner__cal" data-cal="-5">◀ West</button>
          <button type="button" class="scanner__cal" data-cal="5">Ost ▶</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .scanner-open {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-accent-dim);
    border-radius: var(--radius-md);
    background:
      radial-gradient(120% 160% at 0% 0%, rgb(111 227 255 / 0.12), transparent 55%),
      var(--color-space-900);
    color: var(--color-star-100);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out);
  }
  .scanner-open:hover {
    border-color: var(--color-accent);
    box-shadow: var(--glow-accent);
  }
  .scanner-open__icon {
    color: var(--color-accent);
    flex: none;
  }
  .scanner-open__icon svg {
    width: 30px;
    height: 30px;
  }
  .scanner-open__text {
    display: grid;
    gap: 2px;
    flex: 1;
  }
  .scanner-open__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
  }
  .scanner-open__go {
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 0.2em 0.6em;
  }

  /* ---- Vollbild-Scanner ---- */
  .scanner {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: #000;
    overflow: hidden;
  }
  .scanner[hidden] {
    display: none;
  }
  .scanner__video,
  .scanner__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .scanner__video {
    object-fit: cover;
  }
  .scanner__canvas {
    pointer-events: none;
  }

  /* ---- Start-Screen ---- */
  .scanner__intro {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: max(env(safe-area-inset-top), 20px) 20px max(env(safe-area-inset-bottom), 20px);
    background:
      radial-gradient(120% 90% at 50% 0%, rgb(111 227 255 / 0.14), transparent 60%),
      linear-gradient(180deg, #060912, #05070f);
  }
  .scanner__intro[hidden] {
    display: none;
  }
  .scanner__x {
    position: absolute;
    top: max(env(safe-area-inset-top), 16px);
    right: 16px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: var(--border-fine);
    background: rgb(255 255 255 / 0.06);
    color: var(--color-star-100);
    font-size: 1rem;
    cursor: pointer;
  }
  .scanner__introcard {
    width: min(28rem, 100%);
    text-align: center;
    display: grid;
    justify-items: center;
    gap: var(--space-4);
  }
  .scanner__introicon {
    display: grid;
    place-items: center;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    background: rgb(111 227 255 / 0.08);
    box-shadow: var(--glow-accent);
  }
  .scanner__introicon svg {
    width: 34px;
    height: 34px;
  }
  .scanner__introtitle {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin: 0;
  }
  .scanner__introlead {
    color: var(--color-star-300);
    max-width: 26ch;
    margin: 0;
  }
  .scanner__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
    text-align: left;
    width: 100%;
    max-width: 22rem;
  }
  .scanner__steps li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    border: var(--border-fine);
    border-radius: var(--radius-md);
    background: var(--color-space-900);
  }
  .scanner__num {
    flex: none;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-space-950);
    background: var(--color-accent);
  }
  .scanner__start {
    width: 100%;
    max-width: 22rem;
    padding: var(--space-4);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-space-950);
    background: var(--color-accent);
    cursor: pointer;
    box-shadow: var(--glow-accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .scanner__start:active {
    transform: scale(0.98);
  }
  .scanner__fineprint {
    color: var(--color-star-500);
  }

  /* ---- Live-Overlay ---- */
  .scanner__ui {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: max(env(safe-area-inset-top), 14px) 14px max(env(safe-area-inset-bottom), 14px);
    pointer-events: none;
  }
  .scanner__ui[hidden] {
    display: none;
  }
  .scanner__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .scanner__heading {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    background: rgb(5 7 15 / 0.62);
    backdrop-filter: blur(6px);
    padding: 0.45em 0.85em;
    border-radius: 999px;
    border: var(--border-fine);
    letter-spacing: 0.12em;
  }
  .scanner__close {
    pointer-events: auto;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: var(--border-fine);
    background: rgb(5 7 15 / 0.62);
    backdrop-filter: blur(6px);
    color: var(--color-star-100);
    font-size: 1.05rem;
    cursor: pointer;
  }
  .scanner__status {
    align-self: center;
    text-align: center;
    max-width: 32ch;
    background: rgb(5 7 15 / 0.6);
    padding: 0.55em 0.95em;
    border-radius: var(--radius-sm);
    border: var(--border-fine);
  }
  .scanner__status:empty {
    display: none;
  }
  .scanner__toast {
    align-self: center;
    text-align: center;
    background: rgb(111 227 255 / 0.14);
    border: 1px solid var(--color-accent-dim);
    color: var(--color-star-100);
    padding: 0.5em 1em;
    border-radius: 999px;
    transition: opacity var(--dur-base) var(--ease-out);
  }
  .scanner__toast[hidden] {
    display: none;
  }
  .scanner__bottom {
    display: grid;
    gap: var(--space-3);
    justify-items: center;
  }
  .scanner__legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
    padding: 0.7em 1em;
    background: rgb(5 7 15 / 0.6);
    backdrop-filter: blur(6px);
    border: var(--border-fine);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-star-300);
  }
  .scanner__legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    white-space: nowrap;
  }
  .scanner__legend .dot {
    flex: none;
    font-style: normal;
  }
  .dot--planet {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
  }
  .dot--arrow {
    color: var(--color-accent);
  }
  .dot--num {
    font-family: var(--font-mono);
    font-size: 0.72em;
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    border-radius: 4px;
    padding: 0 0.3em;
  }
  .scanner__calibrow {
    display: grid;
    justify-items: center;
    gap: var(--space-2);
  }
  .scanner__calibhint {
    color: var(--color-star-500);
  }
  .scanner__calib {
    display: flex;
    gap: var(--space-2);
    pointer-events: auto;
  }
  .scanner__cal {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-star-100);
    background: rgb(5 7 15 / 0.62);
    backdrop-filter: blur(6px);
    border: var(--border-fine);
    border-radius: 999px;
    padding: 0.5em 1.1em;
    cursor: pointer;
  }
</style>

<script>
  import { horizontalPositions, type SkyBody } from '../lib/sky';

  const ALLGAEU = { lat: 47.7, lon: 10.3 };
  const COLORS: Record<string, string> = {
    sonne: '#ffcf6b',
    mond: '#d5dae6',
    merkur: '#b7a894',
    venus: '#f0d9a8',
    mars: '#e0714a',
    jupiter: '#e6c79a',
    saturn: '#ecd9a3',
  };
  const DEG = Math.PI / 180;
  const FOV_X = 62; // angenommenes horizontales Sichtfeld der Kamera (Grad)

  const scanner = document.getElementById('sky-scanner');
  const openBtn = document.querySelector<HTMLElement>('[data-scanner-open]');
  if (scanner && openBtn) {
    // Overlay an <body> hängen, damit position:fixed nicht von einem
    // transformierten Eltern-Element (reveal-Animation) eingefangen wird.
    document.body.appendChild(scanner);
    const video = scanner.querySelector<HTMLVideoElement>('.scanner__video')!;
    const canvas = scanner.querySelector<HTMLCanvasElement>('.scanner__canvas')!;
    const ctx = canvas.getContext('2d')!;
    const introEl = scanner.querySelector<HTMLElement>('[data-intro]')!;
    const introNote = scanner.querySelector<HTMLElement>('[data-intro-note]')!;
    const liveUi = scanner.querySelector<HTMLElement>('[data-liveui]')!;
    const statusEl = scanner.querySelector<HTMLElement>('[data-scanner-status]')!;
    const headingEl = scanner.querySelector<HTMLElement>('[data-scanner-heading]')!;
    const toastEl = scanner.querySelector<HTMLElement>('[data-scanner-toast]')!;

    let stream: MediaStream | null = null;
    let orient: DeviceOrientationEvent | null = null;
    let bodies: SkyBody[] = [];
    let raf = 0;
    let azOffset = 0;
    let loc = { ...ALLGAEU };
    let toastTimer = 0;
    let usingAbsolute = false;

    // Nur EINE Sensorquelle verwenden. deviceorientation (relativ) und
    // deviceorientationabsolute (magnetisch, echtes Nord) haben auf Android
    // unterschiedliche Nordreferenzen — beide gleichzeitig zu lesen liess die
    // Marker Frame fuer Frame zwischen zwei Positionen springen. Sobald eine
    // absolute Quelle liefert, gewinnt sie; die relative wird dann ignoriert.
    const onAbs = (e: DeviceOrientationEvent) => {
      usingAbsolute = true;
      orient = e;
    };
    const onRel = (e: DeviceOrientationEvent) => {
      if (!usingAbsolute) orient = e;
    };
    const status = (t: string) => (statusEl.textContent = t);
    const hasSensors = typeof DeviceOrientationEvent !== 'undefined';

    /* Start-Screen zeigen (echtes Vollbild anfordern, wo möglich) */
    function showIntro() {
      scanner!.hidden = false;
      introEl.hidden = false;
      liveUi.hidden = true;
      document.body.style.overflow = 'hidden';
      const el = scanner as unknown as { requestFullscreen?: () => Promise<void>; webkitRequestFullscreen?: () => void };
      try {
        if (el.requestFullscreen) void el.requestFullscreen();
        else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
      } catch {
        /* Vollbild optional */
      }
      if (!hasSensors) {
        introNote.textContent = 'Dein Gerät hat keine Bewegungssensoren — am Handy funktioniert es am besten.';
      }
    }

    /* Sensoren + Kamera starten, dann Live-Ansicht */
    async function start() {
      status('Sensoren & Kamera werden gestartet …');

      // iOS: Bewegungssensor-Freigabe (nur per Nutzergeste möglich)
      try {
        const D = DeviceOrientationEvent as unknown as { requestPermission?: () => Promise<string> };
        if (typeof D.requestPermission === 'function') {
          const r = await D.requestPermission();
          if (r !== 'granted') status('Bewegungssensor nicht freigegeben — die Ausrichtung ist eingeschränkt.');
        }
      } catch {
        /* ignorieren */
      }
      usingAbsolute = false;
      if ('ondeviceorientationabsolute' in window) {
        window.addEventListener('deviceorientationabsolute', onAbs as EventListener);
      }
      window.addEventListener('deviceorientation', onRel);

      // Kamera
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: 'environment' } },
          audio: false,
        });
        video.srcObject = stream;
        await video.play();
        status('');
      } catch {
        status('Ohne Kamera-Freigabe kann der Scanner das Himmelsbild nicht zeigen. Bitte Kamera erlauben und erneut öffnen.');
      }

      // Standort (nur lokal genutzt), sonst Allgäu
      navigator.geolocation?.getCurrentPosition(
        (p) => {
          loc = { lat: p.coords.latitude, lon: p.coords.longitude };
          recompute();
        },
        () => {},
        { enableHighAccuracy: false, timeout: 6000, maximumAge: 600000 }
      );

      introEl.hidden = true;
      liveUi.hidden = false;
      smoothQ = null; // beim Öffnen sofort auf die aktuelle Lage schnappen
      recompute();
      resize();

      // Hinweis-Toast nach einigen Sekunden ausblenden
      toastEl.hidden = false;
      clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => (toastEl.hidden = true), 5000);

      loop();
    }

    function close() {
      cancelAnimationFrame(raf);
      clearTimeout(toastTimer);
      window.removeEventListener('deviceorientation', onRel);
      window.removeEventListener('deviceorientationabsolute', onAbs as EventListener);
      stream?.getTracks().forEach((t) => t.stop());
      stream = null;
      smoothQ = null;
      document.body.style.overflow = '';
      const d = document as unknown as { exitFullscreen?: () => Promise<void>; webkitExitFullscreen?: () => void };
      try {
        if (document.fullscreenElement && d.exitFullscreen) void d.exitFullscreen();
        else if (d.webkitExitFullscreen) d.webkitExitFullscreen();
      } catch {
        /* ignorieren */
      }
      scanner!.hidden = true;
      status('');
    }

    function recompute() {
      bodies = horizontalPositions(new Date(), loc.lat, loc.lon);
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const compass = (az: number) => {
      const dirs = ['N', 'NO', 'O', 'SO', 'S', 'SW', 'W', 'NW'];
      return dirs[Math.round(az / 45) % 8];
    };

    function rotMatrix(e: DeviceOrientationEvent) {
      let alpha = e.alpha ?? 0;
      const anyE = e as unknown as { webkitCompassHeading?: number };
      if (typeof anyE.webkitCompassHeading === 'number') alpha = 360 - anyE.webkitCompassHeading;
      const a = alpha * DEG;
      const b = (e.beta ?? 0) * DEG;
      const g = (e.gamma ?? 0) * DEG;
      const cA = Math.cos(a), sA = Math.sin(a);
      const cB = Math.cos(b), sB = Math.sin(b);
      const cG = Math.cos(g), sG = Math.sin(g);
      // Gerät -> Welt (Ost, Nord, Oben), ZXY
      return [
        cA * cG - sA * sB * sG, -cB * sA, cA * sG + cG * sA * sB,
        cG * sA + cA * sB * sG, cA * cB, sA * sG - cA * cG * sB,
        -cB * sG, sB, cB * cG,
      ];
    }

    // --- Weiche Ausrichtung: Sensor-Jitter per Quaternion-Slerp dämpfen. ---
    // Ruhig beim Stillhalten, flüssig folgend beim Schwenken. Slerp meidet
    // zusätzlich Sprünge beim Nord-Übergang (360°/0°).
    const SMOOTH_MIN = 0.09; // Grunddämpfung pro Frame (kleiner = ruhiger)
    let smoothQ: number[] | null = null;

    function matToQuat(R: number[]): number[] {
      const m00 = R[0], m10 = R[1], m20 = R[2];
      const m01 = R[3], m11 = R[4], m21 = R[5];
      const m02 = R[6], m12 = R[7], m22 = R[8];
      const tr = m00 + m11 + m22;
      let w: number, x: number, y: number, z: number, S: number;
      if (tr > 0) {
        S = Math.sqrt(tr + 1) * 2; w = 0.25 * S;
        x = (m21 - m12) / S; y = (m02 - m20) / S; z = (m10 - m01) / S;
      } else if (m00 > m11 && m00 > m22) {
        S = Math.sqrt(1 + m00 - m11 - m22) * 2; w = (m21 - m12) / S;
        x = 0.25 * S; y = (m01 + m10) / S; z = (m02 + m20) / S;
      } else if (m11 > m22) {
        S = Math.sqrt(1 + m11 - m00 - m22) * 2; w = (m02 - m20) / S;
        x = (m01 + m10) / S; y = 0.25 * S; z = (m12 + m21) / S;
      } else {
        S = Math.sqrt(1 + m22 - m00 - m11) * 2; w = (m10 - m01) / S;
        x = (m02 + m20) / S; y = (m12 + m21) / S; z = 0.25 * S;
      }
      return [x, y, z, w];
    }

    function quatToMat(q: number[]): number[] {
      const [x, y, z, w] = q;
      return [
        1 - 2 * (y * y + z * z), 2 * (x * y + w * z), 2 * (x * z - w * y),
        2 * (x * y - w * z), 1 - 2 * (x * x + z * z), 2 * (y * z + w * x),
        2 * (x * z + w * y), 2 * (y * z - w * x), 1 - 2 * (x * x + y * y),
      ];
    }

    function smoothRotation(R: number[]): number[] {
      const q = matToQuat(R);
      if (!smoothQ) { smoothQ = q; return R; }
      let dot = q[0] * smoothQ[0] + q[1] * smoothQ[1] + q[2] * smoothQ[2] + q[3] * smoothQ[3];
      if (dot < 0) { for (let i = 0; i < 4; i++) q[i] = -q[i]; dot = -dot; }
      dot = Math.min(1, Math.max(-1, dot));
      // Winkel zwischen alter und neuer Ausrichtung → adaptiver Faktor:
      // still = stark glätten, schnelle Bewegung = zügiger nachziehen.
      const delta = 2 * Math.acos(Math.min(1, Math.abs(dot)));
      const t = Math.min(0.6, SMOOTH_MIN + delta * 2.2);
      let a: number, b: number;
      if (dot > 0.9995) {
        a = 1 - t; b = t;
      } else {
        const th = Math.acos(dot), s = Math.sin(th);
        a = Math.sin((1 - t) * th) / s; b = Math.sin(t * th) / s;
      }
      const o = [
        smoothQ[0] * a + q[0] * b, smoothQ[1] * a + q[1] * b,
        smoothQ[2] * a + q[2] * b, smoothQ[3] * a + q[3] * b,
      ];
      const n = Math.hypot(o[0], o[1], o[2], o[3]) || 1;
      smoothQ = [o[0] / n, o[1] / n, o[2] / n, o[3] / n];
      return quatToMat(smoothQ);
    }

    function loop() {
      raf = requestAnimationFrame(loop);
      const W = window.innerWidth;
      const H = window.innerHeight;
      ctx.clearRect(0, 0, W, H);
      if (!orient) return;

      const R = smoothRotation(rotMatrix(orient));
      const focal = W / 2 / Math.tan((FOV_X / 2) * DEG);
      const scrAngle = ((screen.orientation?.angle ?? 0) as number) * DEG;
      const cs = Math.cos(scrAngle), sn = Math.sin(scrAngle);

      const lookAz = ((Math.atan2(-R[2], -R[5]) / DEG) + 360) % 360;
      headingEl.textContent = `${compass(lookAz)} · ${Math.round(lookAz)}°`;

      for (const bdy of bodies) {
        const a = (bdy.az - azOffset) * DEG;
        const el = bdy.alt * DEG;
        const E = Math.sin(a) * Math.cos(el);
        const N = Math.cos(a) * Math.cos(el);
        const U = Math.sin(el);
        let dx = E * R[0] + N * R[3] + U * R[6];
        let dy = E * R[1] + N * R[4] + U * R[7];
        const dz = E * R[2] + N * R[5] + U * R[8];
        const rx = dx * cs + dy * sn;
        const ry = -dx * sn + dy * cs;
        dx = rx; dy = ry;

        const depth = -dz;
        const below = bdy.alt < 0;
        if (depth > 0.06) {
          const x = W / 2 + focal * (dx / depth);
          const y = H / 2 - focal * (dy / depth);
          if (x > -60 && x < W + 60 && y > -60 && y < H + 60) {
            drawMarker(x, y, bdy, below);
            continue;
          }
        }
        drawEdgeArrow(dx, dy, bdy, W, H);
      }
    }

    function labelPill(x: number, y: number, text: string, sub: string, col: string) {
      ctx.font = "600 15px 'Space Grotesk Variable', system-ui, sans-serif";
      const w1 = ctx.measureText(text).width;
      ctx.font = "11px 'JetBrains Mono Variable', monospace";
      const w2 = ctx.measureText(sub).width;
      const w = Math.max(w1, w2) + 16;
      const h = 38;
      // Hintergrund-Pille für gute Lesbarkeit über dem Kamerabild
      ctx.fillStyle = 'rgba(5,7,15,0.6)';
      roundRect(x, y - h / 2, w, h, 8);
      ctx.fill();
      ctx.strokeStyle = col;
      ctx.lineWidth = 1;
      roundRect(x, y - h / 2, w, h, 8);
      ctx.stroke();
      ctx.textAlign = 'left';
      ctx.font = "600 15px 'Space Grotesk Variable', system-ui, sans-serif";
      ctx.fillStyle = '#fff';
      ctx.fillText(text, x + 8, y - 3);
      ctx.font = "11px 'JetBrains Mono Variable', monospace";
      ctx.fillStyle = col;
      ctx.fillText(sub, x + 8, y + 13);
    }

    function roundRect(x: number, y: number, w: number, h: number, r: number) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    function drawMarker(x: number, y: number, b: SkyBody, below: boolean) {
      const col = COLORS[b.id] ?? '#8b97b5';
      ctx.globalAlpha = below ? 0.45 : 1;
      ctx.strokeStyle = col;
      ctx.fillStyle = col;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(x, y, 15, 0, Math.PI * 2);
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(x, y, 2.5, 0, Math.PI * 2);
      ctx.fill();
      for (const [ex, ey] of [[-22, 0], [22, 0], [0, -22], [0, 22]] as const) {
        ctx.beginPath();
        ctx.moveTo(x + ex * 0.7, y + ey * 0.7);
        ctx.lineTo(x + ex, y + ey);
        ctx.stroke();
      }
      labelPill(x + 24, y, b.name, below ? 'unter dem Horizont' : `${Math.round(b.alt)}° hoch`, col);
      ctx.globalAlpha = 1;
    }

    function drawEdgeArrow(dx: number, dy: number, b: SkyBody, W: number, H: number) {
      const col = COLORS[b.id] ?? '#8b97b5';
      const cx = W / 2, cy = H / 2;
      const ang = Math.atan2(-dy, dx);
      const rad = Math.min(W, H) * 0.4;
      const x = cx + Math.cos(ang) * rad;
      const y = cy + Math.sin(ang) * rad;
      ctx.globalAlpha = 0.9;
      ctx.fillStyle = col;
      ctx.save();
      ctx.translate(x, y);
      ctx.rotate(ang);
      ctx.beginPath();
      ctx.moveTo(12, 0);
      ctx.lineTo(-7, -7);
      ctx.lineTo(-7, 7);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
      ctx.font = "600 13px 'Space Grotesk Variable', system-ui, sans-serif";
      ctx.textAlign = 'center';
      ctx.fillStyle = '#fff';
      ctx.fillText(b.name, x, y - 14);
      ctx.globalAlpha = 1;
    }

    openBtn.addEventListener('click', showIntro);
    scanner.querySelector('[data-scanner-start]')?.addEventListener('click', () => void start());
    scanner.querySelectorAll('[data-scanner-close]').forEach((b) => b.addEventListener('click', close));
    scanner.querySelectorAll<HTMLElement>('[data-cal]').forEach((btn) =>
      btn.addEventListener('click', () => {
        azOffset += Number(btn.dataset.cal);
      })
    );
    window.addEventListener('resize', () => !scanner.hidden && resize());
    setInterval(() => !scanner.hidden && recompute(), 30000);
  }
</script>
