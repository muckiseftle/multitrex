---
/**
 * AR-Himmelsscanner (Beta): öffnet die Rückkamera im Vollbild und blendet über
 * das Live-Bild die echten Positionen von Sonne, Mond und den hellen Planeten
 * ein — Handy an den Himmel halten. Rein clientseitig (Kamera/Sensoren/Standort
 * verlassen das Gerät nicht). Am besten mobil mit Bewegungssensoren.
 */
---

<button type="button" class="scanner-open" data-scanner-open>
  <span class="scanner-open__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M3 8V5a2 2 0 0 1 2-2h3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3" />
      <circle cx="12" cy="12" r="3.2" />
    </svg>
  </span>
  <span class="scanner-open__text">
    <span class="scanner-open__title">Himmels-Scanner öffnen</span>
    <span class="label scanner-open__sub">Handy an den Himmel halten · Beta</span>
  </span>
  <span class="label label--accent scanner-open__go" aria-hidden="true">AR</span>
</button>

<div class="scanner" id="sky-scanner" hidden>
  <video class="scanner__video" playsinline muted></video>
  <canvas class="scanner__canvas"></canvas>

  <!-- ========== Start-Screen ========== -->
  <div class="scanner__intro" data-intro>
    <button type="button" class="scanner__x" data-scanner-close aria-label="Schließen">✕</button>
    <div class="scanner__introcard">
      <span class="scanner__introicon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
          <path d="M3 8V5a2 2 0 0 1 2-2h3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3" />
          <circle cx="12" cy="12" r="3.2" />
        </svg>
      </span>
      <h2 class="scanner__introtitle">Himmels-Scanner</h2>
      <p class="scanner__introlead">
        Halte dein Handy an den Himmel — der Scanner zeigt dir live, wo Sonne,
        Mond und die Planeten gerade stehen.
      </p>
      <ol class="scanner__steps">
        <li><span class="scanner__num">1</span> Kamera &amp; Bewegung erlauben</li>
        <li><span class="scanner__num">2</span> Handy nach oben zum Himmel halten</li>
        <li><span class="scanner__num">3</span> Den beschrifteten Markern folgen</li>
      </ol>
      <button type="button" class="scanner__start" data-scanner-start>Scanner starten</button>
      <p class="scanner__fineprint label" data-intro-note>
        Am besten am Handy · nichts wird gespeichert oder gesendet
      </p>
    </div>
  </div>

  <!-- ========== Live-AR ========== -->
  <div class="scanner__ui" data-liveui hidden>
    <div class="scanner__top">
      <p class="label scanner__heading">
        <span class="scanner__compass" aria-hidden="true">🧭</span>
        <span data-scanner-heading>—</span>
      </p>
      <button type="button" class="scanner__close" data-scanner-close aria-label="Scanner schließen">✕</button>
    </div>

    <p class="scanner__status label" data-scanner-status></p>

    <div class="scanner__toast label" data-scanner-toast>
      Schwenke dein Handy langsam über den Himmel
    </div>

    <div class="scanner__bottom">
      <div class="scanner__legend">
        <span><i class="dot dot--planet"></i> Planet / Mond / Sonne</span>
        <span><i class="dot dot--arrow">➤</i> Pfeil = dorthin drehen</span>
        <span><i class="dot dot--num">20°</i> Höhe über dem Horizont</span>
      </div>
      <div class="scanner__calibrow">
        <span class="label scanner__calibhint" data-cal-hint>Marker daneben? In Sekunden exakt ausrichten:</span>
        <div class="scanner__calib" data-calib-idle>
          <button type="button" class="scanner__cal scanner__cal--primary" data-cal-start>◎ An Sonne/Mond ausrichten</button>
          <button type="button" class="scanner__cal" data-cal="-1">−1°</button>
          <button type="button" class="scanner__cal" data-cal="1">+1°</button>
          <button type="button" class="scanner__cal" data-cal-reset hidden>Zurücksetzen</button>
        </div>
        <div class="scanner__calib" data-calib-active hidden>
          <button type="button" class="scanner__cal scanner__cal--primary" data-cal-confirm>✓ Passt!</button>
          <button type="button" class="scanner__cal" data-cal-cancel>Abbrechen</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .scanner-open {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-accent-dim);
    border-radius: var(--radius-md);
    background:
      radial-gradient(120% 160% at 0% 0%, rgb(111 227 255 / 0.12), transparent 55%),
      var(--color-space-900);
    color: var(--color-star-100);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out);
  }
  .scanner-open:hover {
    border-color: var(--color-accent);
    box-shadow: var(--glow-accent);
  }
  .scanner-open__icon {
    color: var(--color-accent);
    flex: none;
  }
  .scanner-open__icon svg {
    width: 30px;
    height: 30px;
  }
  .scanner-open__text {
    display: grid;
    gap: 2px;
    flex: 1;
  }
  .scanner-open__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
  }
  .scanner-open__go {
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 0.2em 0.6em;
  }

  /* ---- Vollbild-Scanner ---- */
  .scanner {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: #000;
    overflow: hidden;
  }
  .scanner[hidden] {
    display: none;
  }
  .scanner__video,
  .scanner__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .scanner__video {
    object-fit: cover;
  }
  .scanner__canvas {
    pointer-events: none;
  }

  /* ---- Start-Screen ---- */
  .scanner__intro {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: max(env(safe-area-inset-top), 20px) 20px max(env(safe-area-inset-bottom), 20px);
    background:
      radial-gradient(120% 90% at 50% 0%, rgb(111 227 255 / 0.14), transparent 60%),
      linear-gradient(180deg, #060912, #05070f);
  }
  .scanner__intro[hidden] {
    display: none;
  }
  .scanner__x {
    position: absolute;
    top: max(env(safe-area-inset-top), 16px);
    right: 16px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: var(--border-fine);
    background: rgb(255 255 255 / 0.06);
    color: var(--color-star-100);
    font-size: 1rem;
    cursor: pointer;
  }
  .scanner__introcard {
    width: min(28rem, 100%);
    text-align: center;
    display: grid;
    justify-items: center;
    gap: var(--space-4);
  }
  .scanner__introicon {
    display: grid;
    place-items: center;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    background: rgb(111 227 255 / 0.08);
    box-shadow: var(--glow-accent);
  }
  .scanner__introicon svg {
    width: 34px;
    height: 34px;
  }
  .scanner__introtitle {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin: 0;
  }
  .scanner__introlead {
    color: var(--color-star-300);
    max-width: 26ch;
    margin: 0;
  }
  .scanner__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
    text-align: left;
    width: 100%;
    max-width: 22rem;
  }
  .scanner__steps li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    border: var(--border-fine);
    border-radius: var(--radius-md);
    background: var(--color-space-900);
  }
  .scanner__num {
    flex: none;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-space-950);
    background: var(--color-accent);
  }
  .scanner__start {
    width: 100%;
    max-width: 22rem;
    padding: var(--space-4);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-space-950);
    background: var(--color-accent);
    cursor: pointer;
    box-shadow: var(--glow-accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .scanner__start:active {
    transform: scale(0.98);
  }
  .scanner__fineprint {
    color: var(--color-star-500);
  }

  /* ---- Live-Overlay ---- */
  .scanner__ui {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: max(env(safe-area-inset-top), 14px) 14px max(env(safe-area-inset-bottom), 14px);
    pointer-events: none;
  }
  .scanner__ui[hidden] {
    display: none;
  }
  .scanner__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .scanner__heading {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    background: rgb(5 7 15 / 0.62);
    backdrop-filter: blur(6px);
    padding: 0.45em 0.85em;
    border-radius: 999px;
    border: var(--border-fine);
    letter-spacing: 0.12em;
  }
  .scanner__close {
    pointer-events: auto;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: var(--border-fine);
    background: rgb(5 7 15 / 0.62);
    backdrop-filter: blur(6px);
    color: var(--color-star-100);
    font-size: 1.05rem;
    cursor: pointer;
  }
  .scanner__status {
    align-self: center;
    text-align: center;
    max-width: 32ch;
    background: rgb(5 7 15 / 0.6);
    padding: 0.55em 0.95em;
    border-radius: var(--radius-sm);
    border: var(--border-fine);
  }
  .scanner__status:empty {
    display: none;
  }
  .scanner__toast {
    align-self: center;
    text-align: center;
    background: rgb(111 227 255 / 0.14);
    border: 1px solid var(--color-accent-dim);
    color: var(--color-star-100);
    padding: 0.5em 1em;
    border-radius: 999px;
    transition: opacity var(--dur-base) var(--ease-out);
  }
  .scanner__toast[hidden] {
    display: none;
  }
  .scanner__bottom {
    display: grid;
    gap: var(--space-3);
    justify-items: center;
  }
  .scanner__legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
    padding: 0.7em 1em;
    background: rgb(5 7 15 / 0.6);
    backdrop-filter: blur(6px);
    border: var(--border-fine);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-star-300);
  }
  .scanner__legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    white-space: nowrap;
  }
  .scanner__legend .dot {
    flex: none;
    font-style: normal;
  }
  .dot--planet {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
  }
  .dot--arrow {
    color: var(--color-accent);
  }
  .dot--num {
    font-family: var(--font-mono);
    font-size: 0.72em;
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    border-radius: 4px;
    padding: 0 0.3em;
  }
  .scanner__calibrow {
    display: grid;
    justify-items: center;
    gap: var(--space-2);
  }
  .scanner__calibhint {
    color: var(--color-star-500);
  }
  .scanner__calib {
    display: flex;
    gap: var(--space-2);
    pointer-events: auto;
  }
  .scanner__cal {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-star-100);
    background: rgb(5 7 15 / 0.62);
    backdrop-filter: blur(6px);
    border: var(--border-fine);
    border-radius: 999px;
    padding: 0.5em 1.1em;
    cursor: pointer;
  }

  .scanner__cal--primary {
    color: var(--color-space-950);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Heading-Pille ist antippbar (5× tippen = Debug-Anzeige) */
  .scanner__heading {
    pointer-events: auto;
  }
</style>

<script>
  import { horizontalPositions, magneticDeclinationDeg, type SkyBody } from '../lib/sky';
  import {
    eulerToMatrix,
    iosAlphaFromCompass,
    quatToMatrix,
    createSmoother,
    worldToDevice,
    lookDirection,
    projectToScreen,
    effectiveFovXDeg,
    norm180,
    type Mat3,
    type Quat,
  } from '../lib/orientation';

  const ALLGAEU = { lat: 47.7, lon: 10.3 };
  const COLORS: Record<string, string> = {
    sonne: '#ffcf6b',
    mond: '#d5dae6',
    merkur: '#b7a894',
    venus: '#f0d9a8',
    mars: '#e0714a',
    jupiter: '#e6c79a',
    saturn: '#ecd9a3',
  };

  const scanner = document.getElementById('sky-scanner');
  const openBtn = document.querySelector<HTMLElement>('[data-scanner-open]');
  if (scanner && openBtn) {
    // Overlay an <body> hängen, damit position:fixed nicht von einem
    // transformierten Eltern-Element (reveal-Animation) eingefangen wird.
    document.body.appendChild(scanner);
    const video = scanner.querySelector<HTMLVideoElement>('.scanner__video')!;
    const canvas = scanner.querySelector<HTMLCanvasElement>('.scanner__canvas')!;
    const ctx = canvas.getContext('2d')!;
    const introEl = scanner.querySelector<HTMLElement>('[data-intro]')!;
    const introNote = scanner.querySelector<HTMLElement>('[data-intro-note]')!;
    const liveUi = scanner.querySelector<HTMLElement>('[data-liveui]')!;
    const statusEl = scanner.querySelector<HTMLElement>('[data-scanner-status]')!;
    const headingEl = scanner.querySelector<HTMLElement>('[data-scanner-heading]')!;
    const toastEl = scanner.querySelector<HTMLElement>('[data-scanner-toast]')!;
    const hintEl = scanner.querySelector<HTMLElement>('[data-cal-hint]')!;
    const calibIdle = scanner.querySelector<HTMLElement>('[data-calib-idle]')!;
    const calibActive = scanner.querySelector<HTMLElement>('[data-calib-active]')!;
    const resetBtn = scanner.querySelector<HTMLButtonElement>('[data-cal-reset]')!;

    /* ---------- Zustand ---------- */
    let stream: MediaStream | null = null;
    let bodies: SkyBody[] = [];
    let raf = 0;
    let loc = { ...ALLGAEU };
    let toastTimer = 0;

    // Orientierungsquellen (Priorität: Fusion > absolut > iOS-Kompass > relativ)
    let aos: { stop?: () => void } | null = null;
    let aosMat: Mat3 | null = null;
    let orient: DeviceOrientationEvent | null = null;
    let usingAbsolute = false;
    let iosFlipped = false; // Kompass-Regime (Kamera über/unter Horizont)
    let magneticRef = false; // Quelle referenziert magnetisch Nord?
    let sourceName = '—';

    // Korrekturen: Deklination (magnetisch → wahr Nord) + Nutzer-Kalibrierung
    let declination = magneticDeclinationDeg(loc.lat, loc.lon);
    let azOffset = 0; // Grad, aus Kalibrierung/Feinjustierung
    let altOffset = 0; // Grad, aus Kalibrierung (klein gehalten)

    let calibrating = false;
    let lastR: Mat3 | null = null;
    let debugHud = false;
    let tapCount = 0;
    let tapTimer = 0;

    const smoother = createSmoother(0.16, 0.07);
    const status = (t: string) => (statusEl.textContent = t);
    const hasSensors = typeof DeviceOrientationEvent !== 'undefined';

    /* ---------- Sensorquellen ---------- */

    // Nur EINE Euler-Quelle verwenden: deviceorientation (relativ) und
    // deviceorientationabsolute (magnetisch) haben unterschiedliche
    // Nordreferenzen — gemischt springen die Marker. Absolute Quelle gewinnt,
    // aber NUR wenn sie echte Daten liefert (Firefox feuert auch mit null).
    const onAbs = (e: DeviceOrientationEvent) => {
      if (e.alpha == null) return;
      usingAbsolute = true;
      orient = e;
    };
    const onRel = (e: DeviceOrientationEvent) => {
      if (!usingAbsolute) orient = e;
    };

    /**
     * AbsoluteOrientationSensor (Android/Chrome): sensorfusionierte Quaternion,
     * robust in jeder Gerätelage (kein Euler-/Gimbal-Problem). Primärquelle,
     * wenn verfügbar; fällt bei Fehlern lautlos auf die Event-Quellen zurück.
     */
    function startAOS() {
      try {
        const Ctor = (
          window as unknown as {
            AbsoluteOrientationSensor?: new (o: { frequency: number }) => {
              quaternion: Quat | null;
              addEventListener: (t: string, f: () => void) => void;
              start: () => void;
              stop: () => void;
            };
          }
        ).AbsoluteOrientationSensor;
        if (!Ctor) return;
        const s = new Ctor({ frequency: 30 });
        s.addEventListener('reading', () => {
          const q = s.quaternion;
          if (q) aosMat = quatToMatrix([q[0], q[1], q[2], q[3]]);
        });
        s.addEventListener('error', () => {
          aosMat = null;
          try {
            s.stop();
          } catch {
            /* egal */
          }
        });
        s.start();
        aos = s;
      } catch {
        aos = null;
        aosMat = null;
      }
    }

    /** Aktuelle Rotationsmatrix Gerät→Welt aus der besten verfügbaren Quelle */
    function currentMatrix(): Mat3 | null {
      if (aosMat) {
        sourceName = 'Fusion (AOS)';
        magneticRef = true;
        return aosMat;
      }
      if (orient && orient.alpha != null) {
        const beta = orient.beta ?? 0;
        const gamma = orient.gamma ?? 0;
        const wch = (orient as unknown as { webkitCompassHeading?: number }).webkitCompassHeading;
        let alpha = orient.alpha;
        if (typeof wch === 'number' && wch >= 0) {
          // iOS: alpha ist relativ — aus dem Kompass rekonstruieren.
          // Regime-abhängig (Kamera über/unter Horizont), sonst 180° Fehler!
          const r = iosAlphaFromCompass(wch, beta, iosFlipped);
          iosFlipped = r.flipped;
          alpha = r.alphaDeg;
          sourceName = 'iOS-Kompass';
          magneticRef = true;
        } else {
          sourceName = usingAbsolute ? 'Absolut (magnetisch)' : 'Relativ (ohne Nordbezug)';
          magneticRef = usingAbsolute;
        }
        return eulerToMatrix(alpha, beta, gamma);
      }
      return null;
    }

    /* ---------- Start / Stopp ---------- */

    function showIntro() {
      scanner!.hidden = false;
      introEl.hidden = false;
      liveUi.hidden = true;
      document.body.style.overflow = 'hidden';
      const el = scanner as unknown as {
        requestFullscreen?: () => Promise<void>;
        webkitRequestFullscreen?: () => void;
      };
      try {
        if (el.requestFullscreen) void el.requestFullscreen();
        else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
      } catch {
        /* Vollbild optional */
      }
      if (!hasSensors) {
        introNote.textContent =
          'Dein Gerät hat keine Bewegungssensoren — am Handy funktioniert es am besten.';
      }
    }

    async function start() {
      status('Sensoren & Kamera werden gestartet …');

      // iOS: Bewegungssensor-Freigabe (nur per Nutzergeste möglich)
      try {
        const D = DeviceOrientationEvent as unknown as {
          requestPermission?: () => Promise<string>;
        };
        if (typeof D.requestPermission === 'function') {
          const r = await D.requestPermission();
          if (r !== 'granted')
            status('Bewegungssensor nicht freigegeben — die Ausrichtung ist eingeschränkt.');
        }
      } catch {
        /* ignorieren */
      }

      usingAbsolute = false;
      aosMat = null;
      iosFlipped = false;
      startAOS();
      if ('ondeviceorientationabsolute' in window) {
        window.addEventListener('deviceorientationabsolute', onAbs as EventListener);
      }
      window.addEventListener('deviceorientation', onRel);

      // Kamera
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: 'environment' } },
          audio: false,
        });
        video.srcObject = stream;
        await video.play();
        status('');
      } catch {
        status(
          'Ohne Kamera-Freigabe kann der Scanner das Himmelsbild nicht zeigen. Bitte Kamera erlauben und erneut öffnen.'
        );
      }

      // Standort (nur lokal genutzt), sonst Allgäu — bestimmt auch die
      // Missweisungs-Korrektur (magnetisch → wahr Nord)
      navigator.geolocation?.getCurrentPosition(
        (p) => {
          loc = { lat: p.coords.latitude, lon: p.coords.longitude };
          declination = magneticDeclinationDeg(loc.lat, loc.lon);
          recompute();
        },
        () => {},
        { enableHighAccuracy: false, timeout: 6000, maximumAge: 600000 }
      );

      introEl.hidden = true;
      liveUi.hidden = false;
      smoother.reset(); // beim Öffnen sofort auf die aktuelle Lage schnappen
      recompute();
      resize();

      toastEl.hidden = false;
      clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => (toastEl.hidden = true), 5000);

      loop();
    }

    function close() {
      cancelAnimationFrame(raf);
      clearTimeout(toastTimer);
      window.removeEventListener('deviceorientation', onRel);
      window.removeEventListener('deviceorientationabsolute', onAbs as EventListener);
      try {
        aos?.stop?.();
      } catch {
        /* egal */
      }
      aos = null;
      aosMat = null;
      orient = null;
      stream?.getTracks().forEach((t) => t.stop());
      stream = null;
      smoother.reset();
      endCalib();
      document.body.style.overflow = '';
      const d = document as unknown as {
        exitFullscreen?: () => Promise<void>;
        webkitExitFullscreen?: () => void;
      };
      try {
        if (document.fullscreenElement && d.exitFullscreen) void d.exitFullscreen();
        else if (d.webkitExitFullscreen) d.webkitExitFullscreen();
      } catch {
        /* ignorieren */
      }
      scanner!.hidden = true;
      status('');
    }

    function recompute() {
      // Refraktion an: das Overlay soll zeigen, wo man Objekte SIEHT
      bodies = horizontalPositions(new Date(), loc.lat, loc.lon, { refraction: true });
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const compass = (az: number) => {
      const dirs = ['N', 'NO', 'O', 'SO', 'S', 'SW', 'W', 'NW'];
      return dirs[Math.round(az / 45) % 8];
    };

    /* ---------- Kalibrierung ---------- */

    /** Bestes Kalibrier-Ziel: Sonne, sonst Mond (muss über dem Horizont stehen) */
    function calibTarget(): SkyBody | null {
      const sun = bodies.find((b) => b.id === 'sonne');
      if (sun && sun.alt > -0.5) return sun;
      const moon = bodies.find((b) => b.id === 'mond');
      if (moon && moon.alt > -0.5) return moon;
      return null;
    }

    function startCalib() {
      const t = calibTarget();
      if (!t) {
        status('Sonne und Mond stehen gerade unter dem Horizont — bitte die ±1°-Knöpfe nutzen.');
        window.setTimeout(() => status(''), 4500);
        return;
      }
      calibrating = true;
      calibIdle.hidden = true;
      calibActive.hidden = false;
      hintEl.textContent =
        t.id === 'sonne'
          ? 'Richte den Kreis in der Bildmitte auf die Sonne (nur über den Bildschirm — nicht mit bloßem Auge!), dann „Passt!" tippen.'
          : 'Richte den Kreis in der Bildmitte genau auf den Mond, dann „Passt!" tippen.';
    }

    function endCalib() {
      calibrating = false;
      calibIdle.hidden = false;
      calibActive.hidden = true;
      hintEl.textContent = 'Marker daneben? In Sekunden exakt ausrichten:';
    }

    function confirmCalib() {
      const t = calibTarget();
      if (t && lastR) {
        const look = lookDirection(lastR);
        const declPart = magneticRef ? declination : 0;
        // Der Nutzer hält die Kamera exakt auf das Objekt: Differenz zwischen
        // berechneter (wahrer) Richtung und Sensor-Blickrichtung = Korrektur.
        azOffset = norm180(t.az - declPart - look.azDeg);
        altOffset = Math.max(-12, Math.min(12, t.alt - look.altDeg));
        resetBtn.hidden = false;
        status(
          `Ausgerichtet an ${t.name} ✓ (${azOffset >= 0 ? '+' : ''}${azOffset.toFixed(1)}° seitlich, ` +
            `${altOffset >= 0 ? '+' : ''}${altOffset.toFixed(1)}° Höhe)`
        );
        window.setTimeout(() => status(''), 4500);
      }
      endCalib();
    }

    function resetCalib() {
      azOffset = 0;
      altOffset = 0;
      resetBtn.hidden = true;
      status('Justierung zurückgesetzt.');
      window.setTimeout(() => status(''), 3000);
    }

    /* ---------- Render-Schleife ---------- */

    function loop() {
      raf = requestAnimationFrame(loop);
      const W = window.innerWidth;
      const H = window.innerHeight;
      ctx.clearRect(0, 0, W, H);

      if (calibrating) drawCrosshair(W, H);

      const Rraw = currentMatrix();
      if (!Rraw) return;
      const R = smoother.step(Rraw);
      lastR = R;

      // Sichtfeld aus dem echten Kamerabild ableiten (Cover-Beschnitt!) —
      // ein festes FOV war im Portrait um Faktor ~1,5 zu groß.
      const fovX = effectiveFovXDeg(W, H, video.videoWidth, video.videoHeight);
      const scrAngle = ((screen.orientation?.angle ??
        (window as unknown as { orientation?: number }).orientation) ??
        0) as number;

      const look = lookDirection(R);
      headingEl.textContent = `${compass(look.azDeg)} · ${Math.round(look.azDeg)}°`;

      // Gesamtkorrektur: Missweisung (nur bei magnetischer Quelle) + Kalibrierung
      const azCorr = (magneticRef ? declination : 0) + azOffset;

      for (const bdy of bodies) {
        const dir = worldToDevice(R, bdy.az - azCorr, bdy.alt - altOffset);
        const p = projectToScreen(dir, W, H, fovX, scrAngle);
        const below = bdy.alt < 0;
        if (p.depth > 0.06 && p.x > -60 && p.x < W + 60 && p.y > -60 && p.y < H + 60) {
          drawMarker(p.x, p.y, bdy, below);
        } else {
          drawEdgeArrow(p.rx, p.ry, bdy, W, H);
        }
      }

      if (debugHud) drawDebug(W, look, fovX);
    }

    /* ---------- Zeichnen ---------- */

    function drawCrosshair(W: number, H: number) {
      const cx = W / 2;
      const cy = H / 2;
      ctx.strokeStyle = '#6fe3ff';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.arc(cx, cy, 26, 0, Math.PI * 2);
      ctx.stroke();
      for (const [dx, dy] of [
        [-40, 0],
        [40, 0],
        [0, -40],
        [0, 40],
      ] as const) {
        ctx.beginPath();
        ctx.moveTo(cx + dx * 0.55, cy + dy * 0.55);
        ctx.lineTo(cx + dx, cy + dy);
        ctx.stroke();
      }
    }

    function drawDebug(W: number, look: { azDeg: number; altDeg: number }, fovX: number) {
      const sun = bodies.find((b) => b.id === 'sonne');
      const lines = [
        `Quelle: ${sourceName}`,
        `Blick: Az ${look.azDeg.toFixed(1)}° · Alt ${look.altDeg.toFixed(1)}°`,
        `Missweisung: ${declination.toFixed(1)}° · Offset: ${azOffset.toFixed(1)}°/${altOffset.toFixed(1)}°`,
        `FOV: ${fovX.toFixed(1)}° · Video ${video.videoWidth}×${video.videoHeight}`,
        sun ? `Sonne berechnet: Az ${sun.az.toFixed(1)}° · Alt ${sun.alt.toFixed(1)}°` : '',
        `Ort: ${loc.lat.toFixed(3)} / ${loc.lon.toFixed(3)}`,
      ].filter(Boolean);
      ctx.font = "11px 'JetBrains Mono Variable', monospace";
      ctx.textAlign = 'left';
      const w = Math.min(W - 24, 250);
      ctx.fillStyle = 'rgba(5,7,15,0.75)';
      ctx.fillRect(12, 64, w, 16 * lines.length + 14);
      ctx.fillStyle = '#6fe3ff';
      lines.forEach((l, i) => ctx.fillText(l, 20, 84 + i * 16));
    }

    function labelPill(x: number, y: number, text: string, sub: string, col: string) {
      ctx.font = "600 15px 'Space Grotesk Variable', system-ui, sans-serif";
      const w1 = ctx.measureText(text).width;
      ctx.font = "11px 'JetBrains Mono Variable', monospace";
      const w2 = ctx.measureText(sub).width;
      const w = Math.max(w1, w2) + 16;
      const h = 38;
      // Hintergrund-Pille für gute Lesbarkeit über dem Kamerabild
      ctx.fillStyle = 'rgba(5,7,15,0.6)';
      roundRect(x, y - h / 2, w, h, 8);
      ctx.fill();
      ctx.strokeStyle = col;
      ctx.lineWidth = 1;
      roundRect(x, y - h / 2, w, h, 8);
      ctx.stroke();
      ctx.textAlign = 'left';
      ctx.font = "600 15px 'Space Grotesk Variable', system-ui, sans-serif";
      ctx.fillStyle = '#fff';
      ctx.fillText(text, x + 8, y - 3);
      ctx.font = "11px 'JetBrains Mono Variable', monospace";
      ctx.fillStyle = col;
      ctx.fillText(sub, x + 8, y + 13);
    }

    function roundRect(x: number, y: number, w: number, h: number, r: number) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    function drawMarker(x: number, y: number, b: SkyBody, below: boolean) {
      const col = COLORS[b.id] ?? '#8b97b5';
      ctx.globalAlpha = below ? 0.45 : 1;
      ctx.strokeStyle = col;
      ctx.fillStyle = col;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(x, y, 15, 0, Math.PI * 2);
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(x, y, 2.5, 0, Math.PI * 2);
      ctx.fill();
      for (const [ex, ey] of [
        [-22, 0],
        [22, 0],
        [0, -22],
        [0, 22],
      ] as const) {
        ctx.beginPath();
        ctx.moveTo(x + ex * 0.7, y + ey * 0.7);
        ctx.lineTo(x + ex, y + ey);
        ctx.stroke();
      }
      labelPill(x + 24, y, b.name, below ? 'unter dem Horizont' : `${Math.round(b.alt)}° hoch`, col);
      ctx.globalAlpha = 1;
    }

    function drawEdgeArrow(dx: number, dy: number, b: SkyBody, W: number, H: number) {
      const col = COLORS[b.id] ?? '#8b97b5';
      const cx = W / 2,
        cy = H / 2;
      const ang = Math.atan2(-dy, dx);
      const rad = Math.min(W, H) * 0.4;
      const x = cx + Math.cos(ang) * rad;
      const y = cy + Math.sin(ang) * rad;
      ctx.globalAlpha = 0.9;
      ctx.fillStyle = col;
      ctx.save();
      ctx.translate(x, y);
      ctx.rotate(ang);
      ctx.beginPath();
      ctx.moveTo(12, 0);
      ctx.lineTo(-7, -7);
      ctx.lineTo(-7, 7);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
      ctx.font = "600 13px 'Space Grotesk Variable', system-ui, sans-serif";
      ctx.textAlign = 'center';
      ctx.fillStyle = '#fff';
      ctx.fillText(b.name, x, y - 14);
      ctx.globalAlpha = 1;
    }

    /* ---------- Events ---------- */

    openBtn.addEventListener('click', showIntro);
    scanner.querySelector('[data-scanner-start]')?.addEventListener('click', () => void start());
    scanner.querySelectorAll('[data-scanner-close]').forEach((b) => b.addEventListener('click', close));
    scanner.querySelector('[data-cal-start]')?.addEventListener('click', startCalib);
    scanner.querySelector('[data-cal-confirm]')?.addEventListener('click', confirmCalib);
    scanner.querySelector('[data-cal-cancel]')?.addEventListener('click', endCalib);
    resetBtn.addEventListener('click', resetCalib);
    scanner.querySelectorAll<HTMLElement>('[data-cal]').forEach((btn) =>
      btn.addEventListener('click', () => {
        azOffset += Number(btn.dataset.cal);
        resetBtn.hidden = azOffset === 0 && altOffset === 0;
      })
    );
    // 5× auf die Kompass-Pille tippen = Debug-Anzeige (für Feld-Tests)
    headingEl.parentElement?.addEventListener('click', () => {
      tapCount += 1;
      clearTimeout(tapTimer);
      tapTimer = window.setTimeout(() => (tapCount = 0), 1600);
      if (tapCount >= 5) {
        tapCount = 0;
        debugHud = !debugHud;
      }
    });
    window.addEventListener('resize', () => !scanner.hidden && resize());
    setInterval(() => !scanner.hidden && recompute(), 30000);
  }
</script>
