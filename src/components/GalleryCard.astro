---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'portfolio'>;
  /** großes Layout für Featured-Einträge */
  wide?: boolean;
  loading?: 'eager' | 'lazy';
}
const { entry, wide = false, loading = 'lazy' } = Astro.props;
const { title, subtitle, image, object, constellation, distance } = entry.data;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
---

<a href={`${base}/portfolio/${entry.id}/`} class:list={['card', { 'card--wide': wide }]}>
  <figure class="card__media">
    <Image
      src={image}
      alt={`Astrofoto: ${title}`}
      width={wide ? 1400 : 800}
      loading={loading}
    />
    <span class="card__corner card__corner--tl" aria-hidden="true"></span>
    <span class="card__corner card__corner--br" aria-hidden="true"></span>
  </figure>
  <div class="card__meta">
    <p class="label label--accent">{object}{constellation && constellation !== '—' ? ` · ${constellation}` : ''}</p>
    <h3 class="card__title">{title}</h3>
    {subtitle && <p class="card__sub">{subtitle}</p>}
    {distance && <p class="label card__dist">{distance}</p>}
  </div>
</a>

<style>
  .card {
    display: block;
    color: inherit;
    border: var(--border-fine);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-space-900);
    transition:
      border-color var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  .card:hover {
    color: inherit;
    border-color: var(--color-accent-dim);
    box-shadow: var(--glow-accent);
    transform: translateY(-3px);
  }

  .card__media {
    position: relative;
    margin: 0;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-out);
  }

  .card:hover .card__media img {
    transform: scale(1.03);
  }

  /* Fadenkreuz-Ecken — Teleskop-Overlay-Ästhetik */
  .card__corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: var(--color-accent);
    border-style: solid;
    border-width: 0;
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-out);
  }

  .card__corner--tl {
    top: 10px;
    left: 10px;
    border-top-width: 1px;
    border-left-width: 1px;
  }

  .card__corner--br {
    bottom: 10px;
    right: 10px;
    border-bottom-width: 1px;
    border-right-width: 1px;
  }

  .card:hover .card__corner {
    opacity: 1;
  }

  .card__meta {
    padding: var(--space-3) var(--space-4) var(--space-4);
  }

  .card__title {
    margin: var(--space-1) 0 0;
    font-size: var(--text-xl);
  }

  .card__sub {
    color: var(--color-star-400);
    margin: var(--space-1) 0 0;
    font-size: var(--text-sm);
  }

  .card__dist {
    margin: var(--space-2) 0 0;
  }
</style>
