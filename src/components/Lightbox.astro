---
/**
 * Bild-Lightbox: Klick öffnet das Bild im Vollbild (natives <dialog>),
 * Klick aufs Bild zoomt, Mausbewegung/Touch schwenkt. Schließen per Esc,
 * Schließen-Button oder Klick auf den Hintergrund. Ohne externe Abhängigkeit.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  /** Anzeigebreite der Vorschau */
  width?: number;
}
const { image, alt, width = 1920 } = Astro.props;
---

<div class="lb" data-lightbox>
  <button type="button" class="lb__trigger" aria-label={`${alt} – vergrößern`}>
    <Image src={image} alt={alt} width={width} loading="eager" fetchpriority="high" quality={80} />
    <span class="lb__hint" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
        <line x1="11" y1="8" x2="11" y2="14"></line>
        <line x1="8" y1="11" x2="14" y2="11"></line>
      </svg>
      Vergrößern
    </span>
  </button>

  <dialog class="lb__dialog" aria-label={alt}>
    <button type="button" class="lb__close" aria-label="Schließen">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="18" y1="6" x2="6" y2="18"></line>
      </svg>
    </button>
    <img class="lb__full" src={image.src} alt={alt} width={image.width} height={image.height} />
  </dialog>
</div>

<style>
  .lb,
  .lb__trigger {
    display: block;
    width: 100%;
  }

  .lb__trigger {
    position: relative;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    line-height: 0;
  }

  .lb__trigger :global(img) {
    width: 100%;
    height: auto;
  }

  .lb__hint {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-star-100);
    background: rgb(5 7 15 / 0.55);
    border: 1px solid rgb(232 237 247 / 0.18);
    padding: 0.55em 0.8em;
    border-radius: var(--radius-sm);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
    pointer-events: none;
  }

  .lb__trigger:hover .lb__hint,
  .lb__trigger:focus-visible .lb__hint {
    opacity: 1;
    transform: none;
  }

  .lb__dialog {
    width: 100vw;
    height: 100svh;
    max-width: 100vw;
    max-height: 100svh;
    padding: 0;
    border: 0;
    background: rgb(3 5 12 / 0.96);
    overflow: hidden;
  }

  .lb__dialog::backdrop {
    background: rgb(3 5 12 / 0.9);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .lb__dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb__full {
    max-width: 96vw;
    max-height: 92svh;
    width: auto;
    height: auto;
    object-fit: contain;
    cursor: zoom-in;
    transition: transform var(--dur-base) var(--ease-out);
    will-change: transform;
  }

  .lb__full.is-zoomed {
    transform: scale(2.4);
    cursor: zoom-out;
  }

  .lb__close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-star-100);
    background: rgb(5 7 15 / 0.6);
    border: 1px solid rgb(232 237 247 / 0.2);
    border-radius: 50%;
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .lb__close:hover {
    border-color: var(--color-accent);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-lightbox]').forEach((lb) => {
    const trigger = lb.querySelector<HTMLButtonElement>('.lb__trigger');
    const dialog = lb.querySelector<HTMLDialogElement>('.lb__dialog');
    const closeBtn = lb.querySelector<HTMLButtonElement>('.lb__close');
    const full = lb.querySelector<HTMLImageElement>('.lb__full');
    if (!trigger || !dialog || !closeBtn || !full) return;

    const resetZoom = () => {
      full.classList.remove('is-zoomed');
      full.style.transformOrigin = '';
    };

    trigger.addEventListener('click', () => dialog.showModal());
    closeBtn.addEventListener('click', () => dialog.close());

    // Klick auf den Hintergrund (nicht auf das Bild) schließt
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    // Klick aufs Bild zoomt rein/raus
    full.addEventListener('click', (e) => {
      e.stopPropagation();
      full.classList.toggle('is-zoomed');
    });

    // Im Zoom folgt der Ausschnitt dem Zeiger/Finger
    full.addEventListener('pointermove', (e) => {
      if (!full.classList.contains('is-zoomed')) return;
      const r = full.getBoundingClientRect();
      const x = ((e.clientX - r.left) / r.width) * 100;
      const y = ((e.clientY - r.top) / r.height) * 100;
      full.style.transformOrigin = `${x}% ${y}%`;
    });

    dialog.addEventListener('close', resetZoom);
  });
</script>
