---
/**
 * Globales Sternenfeld — wird zur Build-Zeit deterministisch generiert
 * (seeded PRNG), als reines SVG ohne Laufzeit-JS. Drei Tiefenebenen,
 * dezentes Funkeln per CSS auf der hellsten Ebene.
 */

// Mulberry32 — kleiner seeded PRNG, damit jeder Build dasselbe Feld erzeugt
function mulberry32(seed: number) {
  return () => {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(47103); // 47.1°N 10.3°O — Allgäu als Seed

type Star = { x: number; y: number; r: number; o: number };

function layer(count: number, rMin: number, rMax: number, oMin: number, oMax: number): Star[] {
  return Array.from({ length: count }, () => ({
    x: Math.round(rand() * 16000) / 10,
    y: Math.round(rand() * 9000) / 10,
    r: Math.round((rMin + rand() * (rMax - rMin)) * 100) / 100,
    o: Math.round((oMin + rand() * (oMax - oMin)) * 100) / 100,
  }));
}

const far = layer(140, 0.4, 0.7, 0.15, 0.35);
const mid = layer(70, 0.7, 1.1, 0.3, 0.55);
const near = layer(28, 1.1, 1.7, 0.5, 0.9);
---

<div class="starfield" aria-hidden="true">
  <svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice">
    <g fill="#e8edf7">
      {far.map((s) => <circle cx={s.x} cy={s.y} r={s.r} opacity={s.o} />)}
    </g>
    <g fill="#e8edf7">
      {mid.map((s) => <circle cx={s.x} cy={s.y} r={s.r} opacity={s.o} />)}
    </g>
    <g class="starfield__near" fill="#ffffff">
      {near.map((s, i) => (
        <circle cx={s.x} cy={s.y} r={s.r} opacity={s.o} style={`--tw-delay: ${(i % 7) * 0.9}s`} />
      ))}
    </g>
  </svg>
</div>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .starfield svg {
    width: 100%;
    height: 100%;
  }

  .starfield__near circle {
    animation: twinkle 6s ease-in-out infinite;
    animation-delay: var(--tw-delay, 0s);
  }

  @keyframes twinkle {
    0%,
    100% {
      opacity: 0.9;
    }
    50% {
      opacity: 0.25;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .starfield__near circle {
      animation: none;
    }
  }
</style>
