---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import DataHud from '../components/DataHud.astro';

import portraitImage from '../assets/photos/teleskop-milchstrasse.jpg';
import tubusImage from '../assets/photos/newton-tubus.jpg';
import mountImage from '../assets/photos/eq6-montierung.jpg';

/*
 * HINWEIS FÜR DEN BETREIBER: Die Texte hier sind ein erster Aufschlag auf
 * Basis der vorhandenen Fotos. Bitte persönliche Details ergänzen/korrigieren —
 * insbesondere: Seit wann? Wie zum Hobby gekommen? Genaue Teleskop-Daten.
 */
const equipment = [
  { label: 'Montierung', value: 'Sky-Watcher EQ6 Pro' },
  { label: 'Teleskop', value: 'Newton-Reflektor' },
  { label: 'Kamera', value: 'Nikon D7500' },
  { label: 'Standort', value: 'Börwang, Allgäu' },
];
---

<Base
  title="Über mich — Multitrex Astrofotografie"
  description="Merlin Gail fotografiert den Nachthimmel über dem Allgäu: Wie aus klaren Nächten, Geduld und einem Newton-Teleskop Bilder von Galaxien und Nebeln entstehen."
>
  <section class="about container">
    <header class="about__head">
      <p class="label label--accent">Über mich</p>
      <h1>Die Nacht ist mein Atelier.</h1>
    </header>

    <figure class="about__hero">
      <Image
        src={portraitImage}
        alt="Merlin Gail neben seinem Newton-Teleskop unter der Milchstraße im Allgäu"
        width={1920}
        loading="eager"
        fetchpriority="high"
        quality={75}
      />
      <figcaption class="label">Allgäu, in einer klaren Neumond-Nacht — die Milchstraße über dem Teleskop.</figcaption>
    </figure>

    <div class="about__body">
      <div class="about__text reveal">
        <h2>Warum Astrofotografie?</h2>
        <p>
          Ich bin Merlin Gail, und ich fotografiere Dinge, die man mit bloßem
          Auge kaum oder gar nicht sehen kann: Galaxien, Nebel,
          Sternentstehungsgebiete. Das Allgäu ist dafür ein Geschenk — weit
          weg von den Lichtglocken der Großstädte gehört unser Himmel zu den
          dunkelsten Deutschlands.
        </p>
        <p>
          Astrofotografie ist Geduldsarbeit: Ein einziges Bild besteht aus
          vielen Einzelbelichtungen, gesammelt über Stunden — manchmal über
          mehrere Nächte. Dazu kommen Stunden der Bildbearbeitung, in denen
          aus verrauschten Rohdaten langsam Strukturen auftauchen, die
          Millionen Lichtjahre entfernt sind.
        </p>
        <p>
          Genau dieser Moment, wenn auf dem Bildschirm zum ersten Mal die
          Spiralarme einer Galaxie sichtbar werden, die das Licht vor
          Millionen Jahren losgeschickt hat — dafür stehe ich nachts auf der
          Wiese.
        </p>
      </div>

      <aside class="about__aside reveal">
        <p class="label label--accent">Equipment</p>
        <DataHud items={equipment} columns={1} />
      </aside>
    </div>

    <div class="about__gear reveal">
      <figure>
        <Image src={tubusImage} alt="Blick in den Newton-Tubus mit Fangspiegel, darüber die Nikon D7500" width={800} loading="lazy" />
        <figcaption class="label">Blick in den Newton-Tubus — oben die Nikon D7500.</figcaption>
      </figure>
      <figure>
        <Image src={mountImage} alt="Sky-Watcher EQ6 Pro Montierung" width={800} loading="lazy" />
        <figcaption class="label">Sky-Watcher EQ6 Pro — das Stativ, das der Erddrehung folgt.</figcaption>
      </figure>
    </div>
  </section>
</Base>

<style>
  .about {
    padding: var(--space-6) 0 var(--space-5);
  }

  .about__head h1 {
    margin-top: var(--space-2);
  }

  .about__hero {
    margin: var(--space-5) 0;
    border: var(--border-fine);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .about__hero figcaption {
    padding: var(--space-2) var(--space-3);
    border-top: var(--border-fine);
  }

  .about__body {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-6);
    align-items: start;
    margin-bottom: var(--space-6);
  }

  .about__aside {
    position: sticky;
    top: 6rem;
  }

  .about__aside .label {
    margin-bottom: var(--space-2);
  }

  .about__gear {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .about__gear figure {
    margin: 0;
    border: var(--border-fine);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .about__gear img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
  }

  .about__gear figcaption {
    padding: var(--space-2) var(--space-3);
    border-top: var(--border-fine);
  }

  @media (max-width: 820px) {
    .about__body,
    .about__gear {
      grid-template-columns: 1fr;
    }

    .about__aside {
      position: static;
    }
  }
</style>
