---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import DataHud from '../../components/DataHud.astro';

export async function getStaticPaths() {
  const entries = await getCollection('portfolio');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const hudItems = [
  d.object && { label: 'Objekt', value: d.object },
  d.objectType && { label: 'Typ', value: d.objectType },
  d.constellation && d.constellation !== '—' && { label: 'Sternbild', value: d.constellation },
  d.distance && { label: 'Entfernung', value: d.distance },
  d.captureDate && { label: 'Aufnahme', value: d.captureDate },
].filter(Boolean) as { label: string; value: string }[];
---

<Base
  title={`${d.title} — Multitrex Astrofotografie`}
  description={d.subtitle ?? `Astrofoto: ${d.title}, aufgenommen im Allgäu von Merlin Gail.`}
>
  <article class="detail container">
    <nav class="detail__back" aria-label="Zurück">
      <a href="/portfolio/" class="label">← Zurück zum Portfolio</a>
    </nav>

    <header class="detail__head">
      <p class="label label--accent">{d.object}</p>
      <h1>{d.title}</h1>
      {d.subtitle && <p class="detail__sub">{d.subtitle}</p>}
    </header>

    <figure class="detail__media">
      <Image
        src={d.image}
        alt={`Astrofoto: ${d.title}`}
        width={1920}
        loading="eager"
        fetchpriority="high"
        quality={80}
      />
    </figure>

    <div class="detail__body">
      <div class="detail__text">
        <Content />
      </div>
      <aside class="detail__aside">
        <DataHud items={hudItems} columns={1} />
      </aside>
    </div>
  </article>
</Base>

<style>
  .detail {
    padding: var(--space-5) 0;
  }

  .detail__back {
    margin-bottom: var(--space-5);
  }

  .detail__head h1 {
    margin-top: var(--space-2);
  }

  .detail__sub {
    color: var(--color-star-400);
    font-size: var(--text-lg);
  }

  .detail__media {
    margin: var(--space-5) 0;
    border: var(--border-fine);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .detail__body {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .detail__text :global(p) {
    color: var(--color-star-100);
  }

  .detail__aside {
    position: sticky;
    top: 6rem;
  }

  @media (max-width: 820px) {
    .detail__body {
      grid-template-columns: 1fr;
    }

    .detail__aside {
      position: static;
    }
  }
</style>
