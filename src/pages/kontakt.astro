---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;

// Reiner E-Mail-Kontakt — bewusst ohne Formular-Drittanbieter, damit keine
// Besucherdaten an Dritte fließen (datensparsam, DSGVO-freundlich).
const mailto = 'mailto:info@multitrex.de?subject=' + encodeURIComponent('Anfrage über astrofotografie-allgaeu.de');
---

<Base
  title="Kontakt — Multitrex Astrofotografie"
  description="Kontakt zu Merlin Gail, Astrofotograf im Allgäu: Fragen zu Bildern, Drucken oder zur Astrofotografie — schreib mir gerne."
>
  <section class="contact container">
    <header class="contact__head">
      <p class="label label--accent">Kontakt</p>
      <h1>Funkkontakt aufnehmen.</h1>
      <p class="contact__lead">
        Fragen zu einem Bild, Interesse an einem Druck oder selbst Lust auf
        Astrofotografie? Schreib mir — ich antworte, sobald die Wolken
        aufziehen.
      </p>
    </header>

    <div class="contact__grid">
      <div class="contact__primary">
        <p class="label label--accent">Schreib mir direkt</p>
        <p class="contact__mail">
          <a href={mailto}>info@multitrex.de</a>
        </p>
        <p>
          <a class="btn" href={mailto}>E-Mail verfassen</a>
        </p>
        <p class="contact__note label">
          Kein Kontaktformular, keine Drittanbieter — deine Nachricht geht
          direkt per E-Mail an mich.
        </p>
      </div>

      <aside class="contact__aside reveal">
        <p class="label label--accent">Standort</p>
        <p class="contact__loc">
          Börwang, Allgäu<br />
          <span class="label">47.7° N · 10.3° O</span>
        </p>
      </aside>
    </div>
  </section>
</Base>

<style>
  .contact {
    padding: var(--space-6) 0 var(--space-5);
  }

  .contact__head {
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }

  .contact__head h1 {
    margin-top: var(--space-2);
  }

  .contact__lead {
    color: var(--color-star-400);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .contact__mail {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    margin: var(--space-2) 0 var(--space-4);
  }

  .contact__note {
    margin-top: var(--space-4);
    max-width: 42ch;
  }

  .contact__aside {
    border: var(--border-fine);
    border-radius: var(--radius-md);
    background: var(--color-space-900);
    padding: var(--space-4);
  }

  .contact__loc {
    margin: var(--space-2) 0 0;
  }

  @media (max-width: 820px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
