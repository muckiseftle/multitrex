---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Starfield from '../components/Starfield.astro';
import { siteConfig } from '../site.config';

interface Props {
  title: string;
  description: string;
  /** Pfad zum OG-Bild relativ zur Site-Root */
  ogImage?: string;
  /** Sternenfeld ausblenden (z.B. auf /sonnensystem, das hat ein eigenes) */
  noStarfield?: boolean;
  /** Seitenspezifische Schema.org-Knoten, die in den @graph aufgenommen werden */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
const { title, description, ogImage = `${base}/og-default.jpg`, noStarfield = false, jsonLd } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

// Site-Root ohne abschließenden Slash, Basis für alle @id-Referenzen
const siteUrl = (Astro.site?.toString() ?? 'https://astrofotografie-allgaeu.de/').replace(/\/$/, '');

// Globale Entitäten: auf jeder Seite identisch, damit Google die Marke
// „Merlin Gail / Astrofotografie im Allgäu" als ein Subjekt versteht.
const globalGraph: Record<string, unknown>[] = [
  {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    url: `${siteUrl}/`,
    name: 'Multitrex — Astrofotografie im Allgäu',
    inLanguage: 'de-DE',
    publisher: { '@id': `${siteUrl}/#person` },
  },
  {
    '@type': 'Person',
    '@id': `${siteUrl}/#person`,
    name: 'Merlin Gail',
    alternateName: 'Multitrex Astrofotografie',
    jobTitle: 'Astrofotograf',
    url: `${siteUrl}/`,
    image: new URL(`${base}/og-default.jpg`, Astro.site).toString(),
    email: 'info@multitrex.de',
    knowsAbout: ['Astrofotografie', 'Deep-Sky-Fotografie', 'Astronomie', 'Nachthimmel'],
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Börwang',
      addressRegion: 'Bayern',
      postalCode: '87490',
      addressCountry: 'DE',
    },
  },
];

const pageNodes = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [...globalGraph, ...pageNodes],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#05070f" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Multitrex — Astrofotografie im Allgäu" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Strukturierte Daten (Schema.org) — hilft Google, die Inhalte und die
         Marke „Astrofotografie im Allgäu" als Entität zu verstehen -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />

    <!-- Cloudflare Web Analytics (cookielos) — lädt nur, wenn ein Token in
         src/site.config.ts hinterlegt ist; sonst passiert nichts -->
    {siteConfig.cloudflareAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${siteConfig.cloudflareAnalyticsToken}"}`}
        is:inline
      />
    )}
  </head>
  <body>
    {!noStarfield && <Starfield />}
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    position: relative;
    z-index: var(--z-content);
    padding-top: 4.25rem; /* Höhe der fixierten Nav */
  }
</style>
